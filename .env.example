# LLM API Key (required for cloud providers like Gemini, OpenAI)
# For Gemini: use your Google AI Studio API key
# For OpenAI: use your OpenAI API key
LLM_API_KEY=your-api-key-here

# Optional: Override LLM provider and model
# LLM_PROVIDER=gemini              # gemini | openai | ollama
# LLM_MODEL=gemini-2.0-flash
# LLM_TEMPERATURE=0.1
# LLM_BASE_URL=                    # custom endpoint (auto-resolved from provider if not set)

# Optional: Override vector DB settings
# VECTORDB_PERSIST_DIR=./chroma_data
# VECTORDB_COLLECTION=schemas
